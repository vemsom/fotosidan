# Fotosidan Configuration

# REQUIRED: Set this to a strong random string to protect admin access
# Generate with: openssl rand -hex 32
ADMIN_SECRET=your_strong_random_secret_here

# Optional settings
SITE_TITLE=Fotosidan
DATABASE_URL=sqlite:///storage/fotosidan.db
STORAGE_PATH=storage
ADMIN_ENABLED=true
MAX_UPLOAD_SIZE=52428800

# Docker only
HOST=0.0.0.0
PORT=8000
ADMIN_PORT=8001
